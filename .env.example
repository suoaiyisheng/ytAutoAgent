# ===== Runtime =====
STAGE1_DATA_DIR=runtime/jobs
STAGE1_MAX_WORKERS=2
STAGE1_TASK_TIMEOUT_SEC=3600
PIPELINE_RETRY_MAX=2
PIPELINE_BATCH_SIZE=4

# ===== Provider Select =====
# qwen | gemini
VLM_PROVIDER=qwen
EMBEDDING_PROVIDER=qwen

# ===== Qwen =====
QWEN_API_KEY=your_qwen_api_key_here
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
QWEN_EMBED_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/embeddings
QWEN_VLM_MODEL=qwen3-vl-flash
QWEN_EMBED_MODEL=text-embedding-v3

# ===== Gemini (optional) =====
GEMINI_API_KEY=
GEMINI_VLM_MODEL=gemini-2.5-flash
GEMINI_EMBED_MODEL=gemini-embedding-001

# ===== Optional =====
# Override dotenv location if needed
# STAGE1_DOTENV_PATH=/absolute/path/to/.env
